# Copy to `.env` and adjust. Vite only exposes `VITE_*` keys to the client.
# Restart `pnpm dev` after changing these.

# Freeze the day countdown so you can explore bins/REWE/food without dying.
# Night/dawn/countdown still run; venue queues still complete.
VITE_DEV_FREEZE_TIMER=true

# Optional: skip night/dawn/countdown and jump straight into playing after Start.
# VITE_DEV_SKIP_INTRO=true
